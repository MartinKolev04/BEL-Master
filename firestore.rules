rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - xp: number (required)
    //   - level: number (required)
    //   - grade: string (optional/null, enum: ["7", "10", "12"])
    //   - streak: number (required)
    //   - lastActive: string (required, ISO 8601)
    //   - achievements: list (required)
    //
    // Collection: quizzes
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - category: string (required)
    //   - score: number (required)
    //   - totalQuestions: number (required)
    //   - xpEarned: number (required)
    //   - timestamp: timestamp (required)
    //   - grade: string (required)
    //
    // Collection: tests
    // Document ID: testId
    // Fields:
    //   - testId: string (required)
    //   - grade: number (required)
    //   - sections: list (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "marthard2004@gmail.com"));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'xp', 'level', 'grade', 'streak', 'lastActive', 'achievements']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.email is string &&
             data.xp is number &&
             data.level is number &&
             (data.grade == null || data.grade in ['7', '10', '12']) &&
             data.streak is number &&
             data.lastActive is string &&
             data.achievements is list &&
             (!('role' in data) || data.role is string);
    }

    function isValidQuiz(data) {
      return data.keys().hasAll(['userId', 'category', 'score', 'totalQuestions', 'xpEarned', 'timestamp', 'grade']) &&
             data.userId == request.auth.uid &&
             data.category is string &&
             data.score is number &&
             data.totalQuestions is number &&
             data.xpEarned is number &&
             data.timestamp is timestamp &&
             (data.grade == null || data.grade is string);
    }

    function isValidLobby(data) {
      return data.keys().hasAll(['id', 'hostId', 'status', 'players', 'questions', 'currentQuestionIndex', 'createdAt', 'roundStatus', 'grid', 'starting']) &&
             data.id is string &&
             data.hostId is string &&
             data.status in ['waiting', 'playing', 'finished'] &&
             data.roundStatus in ['question', 'picking'] &&
             data.starting is bool &&
             data.players is map &&
             data.questions is list &&
             data.grid is list &&
             data.currentQuestionIndex is number &&
             data.createdAt is timestamp &&
             (!('questionStartedAt' in data) || data.questionStartedAt is number) &&
             (!('winnerId' in data) || data.winnerId == null || data.winnerId is string);
    }

    function isLobbyPlayer(lobbyData) {
      return isAuthenticated() && request.auth.uid in lobbyData.players.keys();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data);
    }

    match /lobbies/{lobbyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.hostId == request.auth.uid &&
                    isValidLobby(request.resource.data);
      allow update: if isAuthenticated() && 
                    isValidLobby(request.resource.data) &&
                    (
                      // Host can update anything
                      resource.data.hostId == request.auth.uid ||
                      // Other players can join or update their own data
                      (request.auth.uid in request.resource.data.players.keys())
                    );
      allow delete: if isAuthenticated() && resource.data.hostId == request.auth.uid;
    }

    match /tests/{testId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
